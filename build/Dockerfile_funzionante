###############################################################################
# CUDA 12.1 + Ubuntu 22.04  –  PyTorch 2.5.1 (wheel cu121)
###############################################################################
FROM nvidia/cuda:12.1.1-devel-ubuntu22.04
LABEL maintainer="UniboNLP"

ARG TORCH_VER=2.5.1
ARG TVISION_VER=0.20.1
ENV DEBIAN_FRONTEND=noninteractive

###############################################################################
# 1) System deps
###############################################################################
RUN apt-get update && apt-get install -y --no-install-recommends \
        python3.11 python3.11-venv python3.11-dev python3-pip \
        build-essential cmake git curl wget unzip zip nano bash \
        libopenblas-dev liblapack-dev \
        libavcodec-dev libavformat-dev libavdevice-dev libavfilter-dev \
        libgl1-mesa-glx libglib2.0-0 \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

###############################################################################
# 2) venv + pip recente
###############################################################################
RUN python3.11 -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"
RUN pip install --no-cache-dir --upgrade pip setuptools wheel \
    && pip install --no-cache-dir gdown wrapt

###############################################################################
# 3) PyTorch 2.5.1 + cu121
###############################################################################
RUN pip install --no-cache-dir \
        torch==${TORCH_VER} \
        torchvision==${TVISION_VER} \
        torchaudio==${TORCH_VER} \
        --index-url https://download.pytorch.org/whl/cu121

###############################################################################
# 4) Pure-python requirements (torch escluso)
###############################################################################
COPY /build/requirements.txt ./requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

###############################################################################
# 5) Librerie che dipendono da Torch
###############################################################################
RUN pip install --no-cache-dir \
        git+https://github.com/huggingface/transformers.git@main \
        git+https://github.com/deepseek-ai/Janus.git \
        --no-build-isolation git+https://github.com/Dao-AILab/flash-attention.git \
        flash-attn==2.7.4.post1 \
        git+https://github.com/facebookresearch/segment-anything.git

###############################################################################
# 6) Detectron2 (source build, deps inclusi)
###############################################################################
ENV PIP_NO_BUILD_ISOLATION=1 PIP_USE_PEP517=0
RUN pip install --no-cache-dir \
        git+https://github.com/facebookresearch/detectron2.git \
        --no-build-isolation \
        --no-binary torch,torchvision,torchaudio

# 7) Ultralytics --------------------------------------------------------------
RUN pip install --no-cache-dir ultralytics==8.3.99

# 7 bis) Trasformers nightly (contiene AutoModelForImageTextToText) ----------
RUN pip install --no-cache-dir --upgrade --force-reinstall \
        git+https://github.com/huggingface/transformers.git@main

# 8) NLP utilities  (senza pin su huggingface_hub)
RUN pip install --no-cache-dir \
        sentence-transformers==3.4.1 --no-deps \
        spacy==3.8.4 nltk==3.9.1 \
    && python -m spacy download en_core_web_md \
    && python -m nltk.downloader wordnet

# 9) Re-install nightly + hub coerente
RUN pip install --no-cache-dir --upgrade --force-reinstall \
        git+https://github.com/huggingface/transformers.git@main \
        huggingface_hub>=0.31.0



###############################################################################
# 9) Project sources
###############################################################################
WORKDIR /workdir
COPY Makefile .
COPY . .

###############################################################################
# 10) Entry-point
###############################################################################
ENTRYPOINT ["make"]
CMD ["-f", "/workdir/Makefile"]

ENV DEBIAN_FRONTEND=dialog
